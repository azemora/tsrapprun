/**
 * ╔══════════════════════════════════════════════════════════════╗
 * ║  Storage Security Rules - tsrapprun                         ║
 * ║                                                             ║
 * ║  POLÍTICA DE SEGURANÇA:                                     ║
 * ║  1. DENY ALL por padrão                                     ║
 * ║  2. Upload máximo: 10MB por arquivo (controle de custo)     ║
 * ║  3. Apenas imagens (image/*) são aceitas                    ║
 * ║  4. Usuários só acessam suas próprias fotos                 ║
 * ║  5. Thumbnails são read-only (geradas por Cloud Functions)  ║
 * ║                                                             ║
 * ║  ESTRUTURA DO BUCKET:                                       ║
 * ║  /users/{userId}/photos/{file}      → fotos privadas        ║
 * ║  /events/{eventId}/photos/{file}    → fotos do evento       ║
 * ║  /events/{eventId}/thumbnails/{file}→ miniaturas (backend)  ║
 * ║                                                             ║
 * ║  CONTROLE DE CUSTOS:                                        ║
 * ║  - 10MB max por arquivo evita uploads abusivos              ║
 * ║  - Apenas content-type image/* (sem vídeos/PDFs)            ║
 * ║  - Thumbnails geradas server-side (menores, menos egress)   ║
 * ║                                                             ║
 * ║  IMPORTANTE: Este arquivo é a versão local das regras.      ║
 * ║  Ao alterar, copie o conteúdo para o Firebase Console →     ║
 * ║  Storage → Rules → Publish                                  ║
 * ║                                                             ║
 * ║  Última atualização: 2026-03-18                             ║
 * ║  Autor: DPO / Angelo                                        ║
 * ╚══════════════════════════════════════════════════════════════╝
 */

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ══════════════════════════════════════════════════════
    // REGRA PADRÃO: NEGAR TUDO
    // Nenhum arquivo pode ser lido ou escrito a menos que
    // uma regra específica permita.
    // ══════════════════════════════════════════════════════
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ══════════════════════════════════════════════════════
    // FOTOS PRIVADAS DO USUÁRIO
    // Caminho: /users/{userId}/photos/{fileName}
    //
    // - Apenas o dono pode ler e escrever
    // - Limite de 10MB por arquivo
    // - Apenas imagens (JPEG, PNG, WebP, HEIC)
    // - Ninguém mais pode acessar (privacidade total)
    // ══════════════════════════════════════════════════════
    match /users/{userId}/photos/{fileName} {
      allow read: if request.auth != null
                  && request.auth.uid == userId;

      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ══════════════════════════════════════════════════════
    // FOTOS DE EVENTOS (compartilhadas entre participantes)
    // Caminho: /events/{eventId}/photos/{fileName}
    //
    // - Qualquer autenticado pode ler (validação fina no Firestore)
    // - Upload: autenticado + 10MB + imagem
    // - Deleção: apenas quem fez upload (via metadata)
    //
    // NOTA: A validação de "é participante do evento"
    // é feita no Firestore rules e no código do app.
    // Storage rules não conseguem fazer get() no Firestore.
    // ══════════════════════════════════════════════════════
    match /events/{eventId}/photos/{fileName} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');

      // Deleção: o metadata.uploadedBy deve ser o uid do usuário
      allow delete: if request.auth != null
                    && resource.metadata['uploadedBy'] == request.auth.uid;
    }

    // ══════════════════════════════════════════════════════
    // THUMBNAILS (somente leitura)
    // Caminho: /events/{eventId}/thumbnails/{fileName}
    //
    // - Geradas automaticamente por Cloud Functions
    // - Nenhum usuário pode escrever aqui
    // - Qualquer autenticado pode ler (para exibir álbuns)
    // - Thumbnails são pequenas (~50KB) = menor custo de egress
    // ══════════════════════════════════════════════════════
    match /events/{eventId}/thumbnails/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
